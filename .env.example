# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=

# The Movie Database API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# IGDB (via Twitch) — https://dev.twitch.tv/console/apps
# Create an app with Client Credentials grant type
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Google Books API key — https://console.cloud.google.com
GOOGLE_BOOKS_API_KEY=

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=
